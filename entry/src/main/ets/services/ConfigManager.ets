import { fileIo } from '@kit.CoreFileKit';
import { util } from '@kit.ArkTS';
import { Subscription } from '../model/Subscription';
import { Constants } from '../common/Constants';
import { Logger } from '../common/Logger';

export class ConfigManager {
  private context: Context;

  constructor(context: Context) {
    this.context = context;
  }

  async importLocalConfig(fileUri: string): Promise<string> {
    // Read the local file content and save it to app storage
    const srcFile = fileIo.openSync(fileUri, fileIo.OpenMode.READ_ONLY);
    const stat = fileIo.statSync(srcFile.fd);
    const buf = new ArrayBuffer(stat.size);
    fileIo.readSync(srcFile.fd, buf);
    fileIo.closeSync(srcFile.fd);

    const decoder = new util.TextDecoder('utf-8');
    const content = decoder.decodeToString(new Uint8Array(buf));

    // Save to subscriptions directory with a generated name
    const dir = `${this.context.filesDir}/${Constants.SUBSCRIPTIONS_DIR}`;
    try {
      fileIo.mkdirSync(dir);
    } catch (e) {
      // Directory may already exist
    }

    const destPath = `${dir}/local-import.yaml`;
    const destFile = fileIo.openSync(destPath, fileIo.OpenMode.CREATE | fileIo.OpenMode.WRITE_ONLY | fileIo.OpenMode.TRUNC);
    fileIo.writeSync(destFile.fd, content);
    fileIo.closeSync(destFile.fd);

    return destPath;
  }

  async generateEngineConfig(subscription: Subscription, selectedNodeName: string): Promise<string> {
    // Read the raw subscription YAML to get full proxy definitions
    const yamlPath = `${this.context.filesDir}/${Constants.SUBSCRIPTIONS_DIR}/${subscription.id}.yaml`;
    let proxiesSection = '';
    try {
      const rawYaml = fileIo.readTextSync(yamlPath);
      proxiesSection = this.extractProxiesSection(rawYaml);
    } catch (e) {
      Logger.error('Failed to read subscription YAML');
      throw new Error('Cannot read subscription config file');
    }

    const config = `# Auto-generated by SkyWalker — do not edit
mixed-port: 7890
mode: global
allow-lan: false
log-level: warning

dns:
  enable: true
  listen: 0.0.0.0:53
  default-nameserver:
    - ${Constants.DEFAULT_DNS_BOOTSTRAP[0]}
    - ${Constants.DEFAULT_DNS_BOOTSTRAP[1]}
  nameserver:
    - ${Constants.DEFAULT_DNS_NAMESERVERS[0]}
    - ${Constants.DEFAULT_DNS_NAMESERVERS[1]}

${proxiesSection}

proxy-groups:
  - name: GLOBAL
    type: select
    proxies:
      - ${selectedNodeName}

rules:
  - MATCH,GLOBAL
`;

    const configPath = this.getActiveConfigPath();
    const file = fileIo.openSync(configPath, fileIo.OpenMode.CREATE | fileIo.OpenMode.WRITE_ONLY | fileIo.OpenMode.TRUNC);
    fileIo.writeSync(file.fd, config);
    fileIo.closeSync(file.fd);

    return configPath;
  }

  getActiveConfigPath(): string {
    return `${this.context.filesDir}/${Constants.ACTIVE_CONFIG_FILENAME}`;
  }

  private extractProxiesSection(rawYaml: string): string {
    // Extract the entire "proxies:" section verbatim from source YAML
    const lines = rawYaml.split('\n');
    const result: string[] = [];
    let inProxies = false;

    for (const line of lines) {
      if (/^proxies\s*:/.test(line)) {
        inProxies = true;
        result.push(line);
        continue;
      }

      if (inProxies) {
        // End of proxies section: next top-level key
        if (/^[a-zA-Z]/.test(line) && !line.startsWith(' ') && !line.startsWith('-')) {
          break;
        }
        result.push(line);
      }
    }

    return result.join('\n');
  }
}
